{
  "name": "recon-mcp",
  "version": "0.1.0",
  "description": "Manage your crypto portfolio with AI agents (Claude Code, Claude Desktop, Cursor) through your Ledger hardware wallet. MCP server that reads balances, DeFi positions (Aave, Compound, Morpho, Uniswap, Lido, EigenLayer), and cross-chain portfolio value, then prepares and signs transactions via Ledger Live over WalletConnect — your keys never leave the device.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "recon-mcp": "dist/index.js",
    "recon-mcp-setup": "dist/setup.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "setup": "node dist/setup.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "ai-agent",
    "ledger",
    "ledger-live",
    "hardware-wallet",
    "walletconnect",
    "crypto",
    "crypto-portfolio",
    "portfolio-management",
    "wallet",
    "wallet-management",
    "defi",
    "defi-portfolio",
    "onchain",
    "transaction-signing",
    "ethereum",
    "arbitrum",
    "polygon",
    "evm",
    "erc20",
    "aave",
    "compound",
    "morpho",
    "uniswap",
    "lido",
    "eigenlayer",
    "swap",
    "bridge",
    "lifi"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@lifi/sdk": "^3.16.3",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@walletconnect/sign-client": "^2.17.0",
    "@walletconnect/utils": "^2.17.0",
    "qrcode-terminal": "^0.12.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
